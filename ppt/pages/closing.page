pageType: final
background:
  type: solid
  color: "$background"
elements:
  - elementId: accent-line
    elementType: shape
    bounds: [0, 0, 1280, 4]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"
  - elementId: thank-you
    elementType: text
    bounds: [240, 160, 800, 70]
    content:
      style: "$title"
      fontSize: 44
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>Terima Kasih</strong></p>
  - elementId: subtitle-line
    elementType: shape
    bounds: [540, 250, 200, 2]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"
  - elementId: team-title
    elementType: text
    bounds: [340, 270, 600, 30]
    content:
      style: "$subtitle"
      align: [center, middle]
      wrap: false
      text: |
        <p>Kelompok Analisis Data Indonesia</p>
  - elementId: member1-icon
    elementType: icon
    bounds: [140, 340, 28, 28]
    iconName: "fas:user"
    fill:
      type: solid
      color: "$primary"
  - elementId: member1
    elementType: text
    bounds: [180, 340, 400, 28]
    content:
      style: "$body"
      fontSize: 18
      align: [left, middle]
      wrap: false
      text: |
        <p>Member A — Analisis Perbandingan Regional</p>
  - elementId: member2-icon
    elementType: icon
    bounds: [140, 390, 28, 28]
    iconName: "fas:user"
    fill:
      type: solid
      color: "$primary"
  - elementId: member2
    elementType: text
    bounds: [180, 390, 400, 28]
    content:
      style: "$body"
      fontSize: 18
      align: [left, middle]
      wrap: false
      text: |
        <p>Member B — Analisis Tren Temporal</p>
  - elementId: member3-icon
    elementType: icon
    bounds: [140, 440, 28, 28]
    iconName: "fas:user"
    fill:
      type: solid
      color: "$primary"
  - elementId: member3
    elementType: text
    bounds: [180, 440, 400, 28]
    content:
      style: "$body"
      fontSize: 18
      align: [left, middle]
      wrap: false
      text: |
        <p>Member C — Analisis Ketimpangan & Distribusi</p>
  - elementId: contact-bar
    elementType: shape
    bounds: [340, 520, 600, 1]
    shapeName: rect
    fill:
      type: solid
      color: "$secondary"
    opacity: 0.4
  - elementId: contact-text
    elementType: text
    bounds: [340, 540, 600, 30]
    content:
      style: "$caption"
      fontSize: 14
      align: [center, middle]
      wrap: false
      text: |
        <p>Data Lakehouse Platform | Indonesia Demographics & Economy</p>
  - elementId: bottom-accent
    elementType: shape
    bounds: [0, 710, 1280, 10]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"
    opacity: 0.1
  - elementId: page-number
    elementType: text
    bounds: [1200, 690, 60, 20]
    content:
      style: "$caption"
      align: [right, middle]
      wrap: false
      text: |
        <p>05</p>
